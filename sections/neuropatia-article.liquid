{% stylesheet %}
/* ── TOKENS ──────────────────────────────────── */
:root {
  --white:     #ffffff;
  --snow:      #f9f8f6;
  --pearl:     #f2f0eb;
  --pearl2:    #e8e5de;
  --ink:       #0d0d0b;
  --ink2:      #252520;
  --ink3:      #4a4a44;
  --ink4:      #8a8a82;
  --ink5:      #b8b8b0;
  --rule:      #dedad2;
  --rule2:     #c8c4ba;
  --navy:      #0f1f35;
  --navy2:     #1a3050;
  --teal:      #0e6b6b;
  --teal-lt:   #e4f4f4;
  --gold:      #c49a3c;
  --gold-lt:   #fdf6e3;
  --red:       #b02a22;
  --red-lt:    #fdf1f0;
  --col:       700px;
  --wide:      980px;
}

/* ── RESET ───────────────────────────────────── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background: var(--white);
  color: var(--ink);
  font-family: 'Mulish', sans-serif;
  font-size: 17px;
  line-height: 1.82;
  -webkit-font-smoothing: antialiased;
}

/* ── TOP UTILITY BAR ─────────────────────────── */
.util-bar {
  background: var(--navy);
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 40px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.util-bar .ub-left {
  display: flex;
  align-items: center;
  gap: 20px;
}
.util-bar .site-name {
  font-family: 'Playfair Display', serif;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.3px;
}
.util-bar .ad-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid rgba(196,154,60,0.4);
  padding: 2px 8px;
}
.util-bar .ub-right {
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}

/* ── HERO ────────────────────────────────────── */
.hero {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}

/* Subtle diagonal texture */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -55deg,
    transparent,
    transparent 60px,
    rgba(255,255,255,0.012) 60px,
    rgba(255,255,255,0.012) 61px
  );
  pointer-events: none;
}

/* Bottom gradient fade to white */
.hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 80px;
  background: linear-gradient(to bottom, transparent, var(--white));
  pointer-events: none;
}

.hero-inner {
  max-width: var(--wide);
  margin: 0 auto;
  padding: 64px 48px 80px;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 56px;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* ── HERO LEFT ───────────────────────────────── */
.hero-left .kicker {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
}
.kicker-dot {
  width: 6px; height: 6px;
  background: var(--gold);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0.5; transform:scale(0.8); }
}

.hero-left h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(34px, 4.5vw, 54px);
  font-weight: 900;
  line-height: 1.08;
  color: #fff;
  letter-spacing: -0.5px;
  margin-bottom: 24px;
}
.hero-left h1 em {
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.72);
}

.hero-deck {
  font-size: 16px;
  font-weight: 300;
  color: rgba(255,255,255,0.6);
  line-height: 1.72;
  margin-bottom: 36px;
  max-width: 440px;
}

.hero-meta {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 28px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.hero-byline {
  font-size: 11px;
  font-weight: 400;
  color: rgba(255,255,255,0.38);
  letter-spacing: 0.3px;
}
.hero-byline strong { color: rgba(255,255,255,0.65); font-weight: 600; }
.hero-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.htag {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  border: 1px solid rgba(255,255,255,0.12);
  padding: 3px 10px;
}

/* ── HERO IMAGE FRAME ────────────────────────── */
.hero-img-frame {
  position: relative;
}
.hero-img-box {
  width: 100%;
  aspect-ratio: 3/4;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  position: relative;
  overflow: hidden;
}
/* Corner accents */
.hero-img-box::before, .hero-img-box::after {
  content: '';
  position: absolute;
  width: 24px; height: 24px;
  border-color: var(--gold);
  border-style: solid;
}
.hero-img-box::before { top:12px; left:12px; border-width:1px 0 0 1px; }
.hero-img-box::after  { bottom:12px; right:12px; border-width:0 1px 1px 0; }

.img-placeholder-icon { font-size: 36px; opacity: 0.2; }
.img-placeholder-text {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.2);
  text-align: center;
  line-height: 1.5;
}

/* Caption strip below image */
.img-caption-strip {
  background: rgba(196,154,60,0.12);
  border: 1px solid rgba(196,154,60,0.2);
  padding: 10px 16px;
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.img-caption-strip .cap-dot {
  width: 4px; height: 4px;
  background: var(--gold);
  border-radius: 50%;
  flex-shrink: 0;
}
.img-caption-strip span {
  font-size: 10px;
  font-weight: 400;
  color: rgba(196,154,60,0.8);
  font-style: italic;
  letter-spacing: 0.2px;
}

/* ── STATS BAND ──────────────────────────────── */
.stats-band {
  background: var(--white);
  border-bottom: 1px solid var(--rule);
  padding: 0 48px;
}
.stats-band-inner {
  max-width: var(--wide);
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3,1fr);
}
.stat-cell {
  padding: 28px 20px;
  border-right: 1px solid var(--rule);
  display: flex;
  align-items: center;
  gap: 20px;
}
.stat-cell:last-child { border-right: none; }
.stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  font-weight: 900;
  color: var(--navy);
  line-height: 1;
  white-space: nowrap;
}
.stat-desc {
  font-size: 12px;
  font-weight: 400;
  color: var(--ink4);
  line-height: 1.5;
}
.stat-desc strong { display:block; font-weight:600; color:var(--ink2); font-size:13px; }

/* ── LAYOUT ──────────────────────────────────── */
.page-wrap {
  max-width: var(--col);
  margin: 0 auto;
  padding: 0 32px;
}

/* ── ARTICLE ─────────────────────────────────── */
.article { padding: 60px 0 20px; }

.article p {
  color: var(--ink2);
  font-weight: 300;
  margin-bottom: 24px;
  font-size: 17px;
}
.article p strong { font-weight: 700; color: var(--ink); }

/* Opening paragraph */
.lede {
  font-family: 'Playfair Display', serif;
  font-size: 21px !important;
  font-style: italic;
  font-weight: 400 !important;
  color: var(--ink2) !important;
  line-height: 1.58 !important;
  margin-bottom: 36px !important;
}

/* ── SECTION HEADS ───────────────────────────── */
.sh {
  margin: 60px 0 28px;
  display: grid;
  grid-template-columns: 3px 1fr;
  gap: 0 18px;
  align-items: start;
}
.sh-bar {
  width: 3px;
  background: var(--navy);
  align-self: stretch;
  min-height: 48px;
}
.sh-content .eyebrow {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 8px;
}
.sh-content h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 3.5vw, 32px);
  font-weight: 900;
  color: var(--ink);
  line-height: 1.15;
  letter-spacing: -0.3px;
}
.sh-content h2 em { font-style: italic; font-weight: 400; color: var(--ink3); }

/* ── PULL QUOTE ──────────────────────────────── */
.pull {
  margin: 48px -16px;
  padding: 36px 44px;
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
.pull::before {
  content: '\201C';
  font-family: 'Playfair Display', serif;
  font-size: 200px;
  font-weight: 900;
  color: rgba(255,255,255,0.04);
  position: absolute;
  top: -30px; left: 20px;
  line-height: 1;
  pointer-events: none;
}
.pull p {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-style: italic;
  font-weight: 400;
  color: #fff;
  line-height: 1.45;
  margin: 0 !important;
  position: relative;
  z-index: 1;
}
.pull p em { color: var(--gold); font-style: normal; font-weight: 700; }

/* ── IMAGE BLOCK (full-width inline) ─────────── */
.img-block {
  margin: 48px -32px;
  position: relative;
}
.img-block-inner {
  width: 100%;
  aspect-ratio: 16/7;
  background: var(--pearl);
  border-top: 3px solid var(--navy);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 14px;
  position: relative;
  overflow: hidden;
}
.img-block-inner::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 40px,
    rgba(0,0,0,0.015) 40px,
    rgba(0,0,0,0.015) 41px
  );
}
.img-block .ph-icon { font-size: 40px; opacity: 0.18; }
.img-block .ph-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ink4);
}
.img-block .ph-sub {
  font-size: 11px;
  font-weight: 300;
  color: var(--ink5);
  font-style: italic;
}
.img-caption {
  padding: 12px 0 0;
  font-size: 11px;
  font-weight: 400;
  color: var(--ink4);
  font-style: italic;
  border-top: 1px solid var(--rule);
  margin: 0 32px;
}

/* ── FLOAT IMAGE (side by side with text) ─── */
.img-float-wrap {
  margin: 36px 0;
  display: grid;
  grid-template-columns: 1fr 240px;
  gap: 28px;
  align-items: start;
}
.img-float-wrap.left {
  grid-template-columns: 240px 1fr;
}
.img-float-box {
  background: var(--pearl);
  border: 1px solid var(--rule);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 10px;
  position: relative;
}
.img-float-box::before {
  content: '';
  position: absolute;
  top: 6px; left: 6px; right: 6px; bottom: 6px;
  border: 1px dashed var(--rule2);
  pointer-events: none;
}
.img-float-box .ph-icon { font-size: 28px; opacity: 0.2; }
.img-float-box .ph-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--ink5);
}
.float-text p { font-size: 16px !important; }

/* ── CALLOUT CARDS ───────────────────────────── */
.callout {
  margin: 40px 0;
  padding: 32px 36px;
  position: relative;
}
.callout-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.callout-label::after {
  content: '';
  flex: 1;
  height: 1px;
}
.callout h4 {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 14px;
  line-height: 1.25;
}
.callout p { font-size: 15px; font-weight: 300; line-height: 1.72; margin-bottom: 10px; }
.callout p:last-child { margin-bottom: 0; }
.callout p strong { font-weight: 600; }

.callout-navy {
  background: var(--navy);
  border-left: 4px solid var(--gold);
}
.callout-navy .callout-label { color: var(--gold); }
.callout-navy .callout-label::after { background: rgba(196,154,60,0.2); }
.callout-navy h4 { color: #fff; }
.callout-navy p { color: rgba(255,255,255,0.65); }
.callout-navy p strong { color: #fff; }

.callout-teal {
  background: var(--teal-lt);
  border-left: 4px solid var(--teal);
}
.callout-teal .callout-label { color: var(--teal); }
.callout-teal .callout-label::after { background: rgba(14,107,107,0.15); }
.callout-teal h4 { color: #0a3d3d; }
.callout-teal p { color: #1a4a4a; }

.callout-red {
  background: var(--red-lt);
  border-left: 4px solid var(--red);
}
.callout-red .callout-label { color: var(--red); }
.callout-red .callout-label::after { background: rgba(176,42,34,0.12); }
.callout-red h4 { color: #6a1410; }
.callout-red p { color: #5a1a18; }

.callout-gold {
  background: var(--gold-lt);
  border-left: 4px solid var(--gold);
  border: 1px solid #e8d098;
}
.callout-gold .callout-label { color: #8a6010; }
.callout-gold .callout-label::after { background: #e8d098; }
.callout-gold h4 { color: var(--ink); }
.callout-gold p { color: var(--ink3); }

/* ── MECHANISM ───────────────────────────────── */
.mechanism {
  margin: 40px 0;
  border: 1px solid var(--rule);
  overflow: hidden;
}
.mech-header {
  background: var(--navy2);
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mech-header span {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
}
.mech-header small {
  font-size: 10px;
  font-weight: 300;
  color: rgba(255,255,255,0.3);
}
.mech-row {
  display: grid;
  grid-template-columns: 64px 1fr;
  border-bottom: 1px solid var(--rule);
  transition: background 0.18s;
}
.mech-row:last-child { border-bottom: none; }
.mech-row:hover { background: var(--snow); }
.mech-num-col {
  background: var(--pearl);
  border-right: 1px solid var(--rule);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 36px;
  font-weight: 900;
  color: var(--navy);
  opacity: 0.18;
}
.mech-body { padding: 22px 26px; }
.mech-body h4 {
  font-family: 'Mulish', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.mech-chip {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  background: var(--navy);
  color: var(--gold);
  padding: 2px 8px;
}
.mech-body p { font-size: 14px; font-weight: 300; color: var(--ink3); line-height: 1.65; margin: 0 !important; }

/* ── FACTS ───────────────────────────────────── */
.fact-grid {
  margin: 32px 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  background: var(--rule);
}
.fact-cell {
  background: var(--white);
  padding: 24px 26px;
}
.fact-cell .fc-num {
  font-family: 'Playfair Display', serif;
  font-size: 44px;
  font-weight: 900;
  color: var(--navy);
  opacity: 0.1;
  line-height: 1;
  margin-bottom: 8px;
}
.fact-cell p { font-size: 14px; font-weight: 300; color: var(--ink3); line-height: 1.6; margin: 0 !important; }
.fact-cell p strong { font-weight: 700; color: var(--ink2); }

/* ── TESTIMONIALS ────────────────────────────── */
.testimony {
  margin: 36px 0;
  padding: 28px 32px;
  background: var(--snow);
  border-top: 3px solid var(--navy);
  position: relative;
}
.testimony .stars { color: var(--gold); font-size: 13px; letter-spacing: 3px; margin-bottom: 14px; }
.testimony blockquote {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-style: italic;
  color: var(--ink2);
  line-height: 1.6;
  margin-bottom: 16px;
}
.testimony .attrib {
  font-size: 11px;
  font-weight: 600;
  color: var(--ink4);
  letter-spacing: 0.3px;
  text-transform: uppercase;
}
.testimony .attrib strong { color: var(--ink2); }

/* ── DIVIDER ─────────────────────────────────── */
.divider {
  margin: 52px 0;
  display: flex;
  align-items: center;
  gap: 0;
}
.divider-line { flex: 1; height: 1px; background: var(--rule); }
.divider-badge {
  background: var(--navy);
  color: var(--gold);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 6px 18px;
  flex-shrink: 0;
}

/* ── CTA ─────────────────────────────────────── */
.cta-section {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
.cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 40px,
    rgba(196,154,60,0.03) 40px,
    rgba(196,154,60,0.03) 41px
  );
}
.cta-top-accent { height: 4px; background: linear-gradient(90deg, var(--teal), var(--gold)); }
.cta-inner {
  max-width: var(--wide);
  margin: 0 auto;
  padding: 72px 48px;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 64px;
  align-items: center;
  position: relative;
  z-index: 1;
}
.cta-left .cta-eyebrow {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}
.cta-left h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 4vw, 46px);
  font-weight: 900;
  color: #fff;
  line-height: 1.12;
  margin-bottom: 18px;
  letter-spacing: -0.3px;
}
.cta-left h2 em { font-style: italic; font-weight: 400; color: rgba(255,255,255,0.6); }
.cta-sub {
  font-size: 15px;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  line-height: 1.65;
}
.cta-right {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.cta-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 24px 28px;
}
.cta-card .cc-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}
.cta-card .cc-price {
  font-family: 'Playfair Display', serif;
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}
.cta-card .cc-sub {
  font-size: 12px;
  color: rgba(255,255,255,0.4);
  font-weight: 300;
}
.cta-btn {
  display: block;
  background: var(--gold);
  color: var(--navy);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 18px 28px;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: filter 0.2s, transform 0.15s;
}
.cta-btn:hover { filter: brightness(1.1); transform: translateY(-2px); }
.cta-guarantees {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-top: 4px;
}
.g-line {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
}
.g-check {
  width: 16px; height: 16px;
  border: 1px solid rgba(196,154,60,0.4);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px;
  color: var(--gold);
  flex-shrink: 0;
}

/* ── SCROLL REVEAL ───────────────────────────── */
.r {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.7s cubic-bezier(.22,.68,0,1.2), transform 0.7s cubic-bezier(.22,.68,0,1.2);
}
.r.in { opacity: 1; transform: none; }

/* ── RESPONSIVE ──────────────────────────────── */
@media (max-width: 860px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 28px 64px; }
  .hero-img-frame { display: none; }
  .stats-band { padding: 0 24px; }
  .stats-band-inner { grid-template-columns: 1fr; }
  .stat-cell { border-right: none; border-bottom: 1px solid var(--rule); padding: 18px 12px; }
  .stat-cell:last-child { border-bottom: none; }
  .cta-inner { grid-template-columns: 1fr; gap: 40px; padding: 52px 28px; }
  footer { padding: 24px 28px; }
  .img-block { margin: 40px -20px; }
  .img-float-wrap, .img-float-wrap.left { grid-template-columns: 1fr; }
  .fact-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .page-wrap { padding: 0 20px; }
  .pull { margin: 36px -12px; padding: 28px 24px; }
  .callout { padding: 24px 22px; }
  .util-bar { padding: 0 16px; }
}
