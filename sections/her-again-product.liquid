<script>
let mode = 'sub';
let subFreq = 2;
let subDisc = 25;
let onceQty = 2;
let oncePrice = 79990;
let onceOg = 119980;
let upsellOn = true;
const upsellPrice = 12990;
let stockN = 28;

const subPrices = {
  1: { disc:20, base:44990 },
  2: { disc:25, base:44990 },
  3: { disc:30, base:44990 }
};

function setMode(m) {
  mode = m;
  const isS = m === 'sub';
  document.getElementById('modeSub').classList.toggle('on', isS);
  document.getElementById('modeOnce').classList.toggle('on', !isS);
  document.getElementById('subPanel').classList.toggle('on', isS);
  document.getElementById('onetimePanel').classList.toggle('off', isS);
  document.getElementById('btnSub').style.display = isS ? 'block' : 'none';
  document.getElementById('btnSub').classList.toggle('on', isS);
  document.getElementById('btnOnce').style.display = isS ? 'none' : 'block';
  recalc();
}

function setFreq(el) {
  document.querySelectorAll('.freq-opt').forEach(o => o.classList.remove('on'));
  el.classList.add('on');
  subFreq = parseInt(el.dataset.freq);
  subDisc = parseInt(el.dataset.disc);
  recalc();
}

function selectQty(el) {
  document.querySelectorAll('.qty-card').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
  onceQty = parseInt(el.dataset.qty);
  oncePrice = parseInt(el.dataset.p);
  onceOg = parseInt(el.dataset.og);
  recalc();
}

function toggleUpsell() {
  upsellOn = !upsellOn;
  document.getElementById('upsellT').classList.toggle('on', upsellOn);
  recalc();
}

function recalc() {
  let baseCLP, ogCLP;
  
  if (mode === 'sub') {
    const d = subPrices[subFreq];
    baseCLP = Math.round(d.base * (1 - d.disc / 100));
    ogCLP = d.base;
    
    document.getElementById('subOg').textContent = ogCLP.toLocaleString('es-CL', { style:'currency', currency:'CLP' });
    document.getElementById('subPrice').innerHTML = `<small>$</small>${baseCLP.toLocaleString('es-CL')}`;
  } else {
    baseCLP = oncePrice;
    ogCLP = onceOg;
  }

  const upCLP = upsellOn ? upsellPrice : 0;
  const totalCLP = baseCLP + upCLP;
  const totalOgCLP = ogCLP + (upsellOn ? 19990 : 0);
  const disc = Math.round((1 - totalCLP / totalOgCLP) * 100);

  document.getElementById('ctaOg').textContent = `$${totalOgCLP.toLocaleString('es-CL')}`;
  document.getElementById('ctaTotal').innerHTML = `<small>$</small>${totalCLP.toLocaleString('es-CL')}`;
  document.getElementById('ctaSave').textContent = `−${disc}%`;
  
  document.getElementById('btnSubPrice').textContent = `$${totalCLP.toLocaleString('es-CL')}`;
  document.getElementById('btnOncePrice').textContent = `$${totalCLP.toLocaleString('es-CL')}`;
}

function toggleAcc(btn) {
  const item = btn.parentElement;
  const open = item.classList.contains('open');
  document.querySelectorAll('.acc').forEach(a => a.classList.remove('open'));
  if (!open) item.classList.add('open');
}

function setSlide(idx, thumb) {
  document.querySelectorAll('.g-slide').forEach(s => s.classList.remove('on'));
  document.querySelectorAll('.g-thumb').forEach(t => t.classList.remove('on'));
  document.getElementById('s' + idx).classList.add('on');
  thumb.classList.add('on');
}

function addToCart(src) {
  alert('Producto agregado al carrito. Integrá con tu sistema Shopify actual.');
}

recalc();
</script>
