<style>

/* ══ TOKENS ══════════════════════════════════ */
:root {
  --white:   #ffffff;
  --snow:    #f9f8f7;
  --fog:     #f2f0ed;
  --fog2:    #e8e5e0;
  --ink:     #0c0c0b;
  --ink2:    #222220;
  --ink3:    #555550;
  --ink4:    #999990;
  --ink5:    #c4c4bc;
  --rule:    #e0ddd8;
  --rule2:   #cccab f;
  --gold:    #b09060;
  --gold2:   #c8aa78;
  --gold-lt: #f7f2ea;
}

/* ══ RESET ═══════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--white);
  color: var(--ink);
  font-family: 'Jost', sans-serif;
  font-weight: 300;
  font-size: 16px;
  line-height: 1.8;
  -webkit-font-smoothing: antialiased;
}

/* ══ NAV ═════════════════════════════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--rule);
  height: 72px;
  display: flex;
  align-items: center;
  padding: 0 48px;
  justify-content: space-between;
}

/* ── Logo SVG ── */
.nav-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  text-decoration: none;
}
.logo-top {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--ink);
  line-height: 1;
}
.logo-rule-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
  justify-content: center;
}
.logo-rule-line {
  flex: 1;
  height: 1px;
  background: var(--ink);
  opacity: 0.4;
}
.logo-bottom {
  font-family: 'Jost', sans-serif;
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--ink);
  line-height: 1;
}

.nav-links {
  display: flex;
  gap: 36px;
  list-style: none;
}
.nav-links a {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--ink3);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }

.nav-cta {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--ink);
  border: 1px solid var(--ink);
  padding: 9px 24px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.nav-cta:hover { background: var(--ink); color: var(--white); }

/* ══ HERO ════════════════════════════════════ */
.hero {
  min-height: 100vh;
  padding: 72px 0 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}

/* Left panel */
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 64px 80px 80px;
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 32px;
}
.hero-badge::before {
  content: '';
  display: block;
  width: 24px;
  height: 1px;
  background: var(--gold);
}

.hero-left h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(42px, 5.5vw, 68px);
  font-weight: 300;
  line-height: 1.05;
  color: var(--ink);
  letter-spacing: -1px;
  margin-bottom: 28px;
}
.hero-left h1 em {
  font-style: italic;
  font-weight: 300;
  color: var(--ink3);
}
.hero-left h1 strong {
  font-weight: 600;
  font-style: normal;
  color: var(--ink);
}

.hero-desc {
  font-size: 15px;
  font-weight: 300;
  color: var(--ink3);
  line-height: 1.75;
  max-width: 400px;
  margin-bottom: 44px;
  border-left: 2px solid var(--rule);
  padding-left: 18px;
}

.hero-actions {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}
.btn-primary {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--white);
  background: var(--ink);
  padding: 16px 40px;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
  display: inline-block;
}
.btn-primary:hover { background: var(--ink2); transform: translateY(-1px); }

.btn-secondary {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--ink3);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: color 0.2s, gap 0.2s;
}
.btn-secondary:hover { color: var(--ink); gap: 12px; }
.btn-secondary::after { content: '→'; }

.hero-proof {
  margin-top: 56px;
  padding-top: 28px;
  border-top: 1px solid var(--rule);
  display: flex;
  gap: 36px;
}
.proof-item { display: flex; flex-direction: column; gap: 2px; }
.proof-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1;
}
.proof-label {
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 1px;
  color: var(--ink4);
  text-transform: uppercase;
}

/* Right panel — image */
.hero-right {
  position: relative;
  background: var(--fog);
  overflow: hidden;
}
.hero-right::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--fog) 0%, var(--fog2) 100%);
}
.hero-img-slot {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  z-index: 1;
}
.hero-img-slot img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.ph-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.ph-icon { font-size: 48px; opacity: 0.12; }
.ph-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ink4);
}
.ph-sub {
  font-size: 11px;
  font-weight: 300;
  color: var(--ink5);
  font-style: italic;
}

/* Corner tag on hero image */
.hero-tag {
  position: absolute;
  bottom: 36px;
  left: 36px;
  z-index: 2;
  background: var(--white);
  border: 1px solid var(--rule);
  padding: 14px 20px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.hero-tag .ht-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
}
.hero-tag .ht-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1;
}
.hero-tag .ht-sub {
  font-size: 10px;
  font-weight: 300;
  color: var(--ink4);
}

/* ══ THERAPY STRIP ═══════════════════════════ */
.therapy-strip {
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  background: var(--white);
}
.therapy-strip-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 0 48px;
}
.therapy-cell {
  padding: 44px 32px;
  border-right: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: background 0.2s;
}
.therapy-cell:last-child { border-right: none; }
.therapy-cell:hover { background: var(--snow); }

.therapy-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 48px;
  font-weight: 300;
  color: var(--ink);
  opacity: 0.07;
  line-height: 1;
}
.therapy-icon {
  font-size: 22px;
  margin-top: -20px;
}
.therapy-cell h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.2;
  letter-spacing: -0.2px;
}
.therapy-cell p {
  font-size: 13px;
  font-weight: 300;
  color: var(--ink3);
  line-height: 1.7;
}
.therapy-tag {
  display: inline-block;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--fog2);
  padding: 3px 10px;
  margin-top: 4px;
  align-self: flex-start;
}

/* ══ PRODUCT SECTION ════════════════════════ */
.product-section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 100px 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* Product image area */
.product-img-area {
  position: relative;
}
.product-main-slot {
  width: 100%;
  aspect-ratio: 4/5;
  background: var(--fog);
  border: 1px solid var(--rule);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 14px;
  position: relative;
  overflow: hidden;
}
.product-main-slot::before {
  content: '';
  position: absolute;
  top: 14px; left: 14px; right: 14px; bottom: 14px;
  border: 1px dashed var(--rule);
  pointer-events: none;
}
.product-main-slot img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: none;
}

/* Floating mini slot */
.product-mini-slot {
  position: absolute;
  bottom: -24px;
  right: -24px;
  width: 140px;
  height: 140px;
  background: var(--white);
  border: 1px solid var(--rule);
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 6px;
}
.product-mini-slot img { width:100%; height:100%; object-fit:cover; display:block; }
.product-mini-slot .ph-title { font-size: 8px; }

/* Product info */
.product-info {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.product-info .eyebrow {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.product-info .eyebrow::before {
  content: '';
  display: block;
  width: 20px;
  height: 1px;
  background: var(--gold);
}
.product-info h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 3.5vw, 46px);
  font-weight: 300;
  color: var(--ink);
  line-height: 1.1;
  letter-spacing: -0.5px;
  margin-bottom: 24px;
}
.product-info h2 strong { font-weight: 700; }
.product-info h2 em { font-style: italic; }

.product-info .desc {
  font-size: 15px;
  font-weight: 300;
  color: var(--ink3);
  line-height: 1.8;
  margin-bottom: 36px;
  padding-bottom: 36px;
  border-bottom: 1px solid var(--rule);
}

.product-features {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 40px;
}
.feat-row {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid var(--fog2);
}
.feat-row:first-child { border-top: none; }
.feat-check {
  width: 20px; height: 20px;
  border: 1px solid var(--ink);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px;
  flex-shrink: 0;
  margin-top: 2px;
}
.feat-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.feat-text strong {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 0.2px;
}
.feat-text span {
  font-size: 12px;
  font-weight: 300;
  color: var(--ink4);
}

.product-info .btn-primary { align-self: flex-start; }

/* ══ HOW IT WORKS ═══════════════════════════ */
.how-section {
  background: var(--fog);
  padding: 100px 48px;
  position: relative;
  overflow: hidden;
}
.how-section::before {
  content: 'EMS+';
  font-family: 'Cormorant Garamond', serif;
  font-size: 240px;
  font-weight: 700;
  color: rgba(0,0,0,0.025);
  position: absolute;
  top: -20px;
  right: -20px;
  line-height: 1;
  pointer-events: none;
  letter-spacing: -8px;
}

.how-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 60px;
  gap: 40px;
}
.section-header .sh-left .eyebrow {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}
.section-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 3.5vw, 44px);
  font-weight: 300;
  color: var(--ink);
  line-height: 1.1;
  letter-spacing: -0.5px;
}
.section-header h2 em { font-style: italic; }
.section-header .sh-right {
  font-size: 14px;
  font-weight: 300;
  color: var(--ink4);
  max-width: 300px;
  text-align: right;
  line-height: 1.6;
  flex-shrink: 0;
}

.steps-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 2px;
  background: var(--rule);
}
.step-card {
  background: var(--white);
  padding: 40px 36px;
  position: relative;
  overflow: hidden;
  transition: background 0.2s;
}
.step-card:hover { background: var(--snow); }
.step-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--ink);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}
.step-card:hover::after { transform: scaleX(1); }

.step-n {
  font-family: 'Cormorant Garamond', serif;
  font-size: 64px;
  font-weight: 700;
  color: var(--ink);
  opacity: 0.06;
  line-height: 1;
  position: absolute;
  top: 20px; right: 24px;
}

/* Step image slot */
.step-img-slot {
  width: 100%;
  aspect-ratio: 4/3;
  background: var(--fog);
  border: 1px solid var(--rule);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 8px;
  overflow: hidden;
  position: relative;
  z-index: 1;
}
.step-img-slot img { width:100%; height:100%; object-fit:cover; display:block; }
.step-img-slot .ph-title { font-size: 8px; letter-spacing: 3px; }

.step-card h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 10px;
  line-height: 1.2;
  position: relative;
  z-index: 1;
}
.step-card p {
  font-size: 13px;
  font-weight: 300;
  color: var(--ink3);
  line-height: 1.7;
  position: relative;
  z-index: 1;
}

/* ══ TESTIMONIALS ═══════════════════════════ */
.testimonials-section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 100px 48px;
}

.testi-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 2px;
  background: var(--rule);
  margin-top: 60px;
}
.testi-card {
  background: var(--white);
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  transition: background 0.2s;
}
.testi-card:hover { background: var(--snow); }

.testi-stars { color: var(--gold); font-size: 13px; letter-spacing: 3px; }

.testi-card blockquote {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-style: italic;
  font-weight: 400;
  color: var(--ink2);
  line-height: 1.6;
  flex: 1;
}

.testi-author {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 14px;
  border-top: 1px solid var(--rule);
}
/* Author image slot */
.testi-avatar {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--fog2);
  border: 1px solid var(--rule);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  overflow: hidden;
  flex-shrink: 0;
}
.testi-avatar img { width:100%; height:100%; object-fit:cover; display:none; }
.testi-info strong {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--ink2);
}
.testi-info span {
  font-size: 11px;
  font-weight: 300;
  color: var(--ink4);
}

/* ══ CTA BAND ═══════════════════════════════ */
.cta-band {
  background: var(--ink);
  padding: 80px 48px;
  position: relative;
  overflow: hidden;
}
.cta-band::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -50deg,
    transparent,
    transparent 50px,
    rgba(255,255,255,0.012) 50px,
    rgba(255,255,255,0.012) 51px
  );
}
.cta-band-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 60px;
  position: relative;
  z-index: 1;
}
.cta-band .eyebrow {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 14px;
}
.cta-band h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 4vw, 46px);
  font-weight: 300;
  color: #fff;
  line-height: 1.12;
  letter-spacing: -0.5px;
  margin-bottom: 14px;
}
.cta-band h2 em { font-style: italic; color: rgba(255,255,255,0.55); }
.cta-band p {
  font-size: 14px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1.65;
}

.cta-band-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14px;
  flex-shrink: 0;
}
.btn-gold {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--ink);
  background: var(--gold2);
  padding: 18px 44px;
  text-decoration: none;
  transition: filter 0.2s, transform 0.15s;
  white-space: nowrap;
}
.btn-gold:hover { filter: brightness(1.1); transform: translateY(-2px); }
.cta-guarantees {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: flex-end;
}
.g-item {
  font-size: 11px;
  font-weight: 300;
  color: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  gap: 8px;
}
.g-dot {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}

/* ══ FOOTER ═════════════════════════════════ */
footer {
  background: var(--snow);
  border-top: 1px solid var(--rule);
}
.footer-inner {
  display: flex;
  flex-direction: column;
}







.footer-bar {
  padding: 22px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.footer-logo-small {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.footer-logo-small .fls-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--ink);
}
.footer-logo-small .fls-sep {
  width: 1px;
  height: 14px;
  background: var(--rule2);
}
.footer-logo-small .fls-tag {
  font-family: 'Jost', sans-serif;
  font-size: 8px;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--ink4);
}
.footer-links-row {
