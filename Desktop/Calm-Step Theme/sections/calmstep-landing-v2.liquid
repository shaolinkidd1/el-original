<script>
// Timer
(function(){
  let t = 23*3600+47*60+12;
  setInterval(function(){
    t = t>0 ? t-1 : 86399;
    var h=String(Math.floor(t/3600)).padStart(2,'0');
    var m=String(Math.floor((t%3600)/60)).padStart(2,'0');
    var s=String(t%60).padStart(2,'0');
    var el=document.getElementById('timer');
    if(el) el.textContent=h+':'+m+':'+s;
  },1000);
})();

// Qty select
function selectQty(el, price){
  document.querySelectorAll('.qty-card').forEach(function(c){c.classList.remove('selected');});
  el.classList.add('selected');
  var stickyEl = document.getElementById('stickyPrice');
  if(stickyEl) stickyEl.textContent = price + ' CLP';
}

// FAQ
function toggleFaq(el){
  el.parentElement.classList.toggle('open');
}

// Cart / Checkout
var _cartUrl = {{ section.settings.cta_url | json }};
var _checkoutUrl = {{ section.settings.checkout_url | json }};

function addToCart(){
  window.location.href = _cartUrl;
}
function goCheckout(){
  window.location.href = _checkoutUrl;
}
</script>

